# SmartPrep AI - Environment Variables
# Copy this file to .env and fill in your values

# Required: Groq API Key (FREE — get one at https://console.groq.com)
GROQ_API_KEY=your-groq-api-key-here

# Model — llama-3.3-70b-versatile is free and high quality
GROQ_MODEL=llama-3.3-70b-versatile

# Embeddings — free local model, no API needed (download on first run)
# Must be supported by fastembed TextEmbedding
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Vector store location
VECTOR_STORE_PATH=./vector_store

# Debug
DEBUG=false
LOG_LEVEL=INFO
