# SmartPrep AI - Environment Variables
# Copy this file to .env and fill in your values

# Required: Groq API Key (FREE — get one at https://console.groq.com)
GROQ_API_KEY=your-groq-api-key-here

# Model — llama-3.3-70b-versatile is free and high quality
GROQ_MODEL=llama-3.3-70b-versatile

# Embeddings — free local model, no API needed (downloaded at build time)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Vector store location
VECTOR_STORE_PATH=./vector_store

# Debug
DEBUG=false
LOG_LEVEL=INFO

# Memory optimisation (default: false)
# The cross-encoder reranker uses ~200 MB extra RAM.
# Only set to true if your instance has >= 1 GB RAM (Render Starter or higher).
ENABLE_RERANKER=false
